{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "type-check": "vue-tsc --noEmit",
        "pnpm-sync": "docker compose -f docker-compose.local.yml exec node sh -lc 'corepack enable && corepack prepare pnpm@9.11.0 --activate && pnpm install'",
        "diagrams:pdf": "for f in docs/diagrams/*.mmd; do pnpm exec mmdc -i \"$f\" -o \"${f%.mmd}.pdf\" -e pdf -s 2 -p docs/diagrams/puppeteer-config.json -q; done"
    },
    "devDependencies": {
        "@mermaid-js/mermaid-cli": "^11.12.0",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.3.5",
        "@vitejs/plugin-vue": "^6.0.4",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^2.3.0",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.7",
        "vue-tsc": "^3.2.5"
    },
    "dependencies": {
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3",
        "bootstrap-icons": "^1.13.1",
        "flatpickr": "^4.6.13",
        "vue": "^3.5.29",
        "vue-i18n": "^11.3.0",
        "vue-router": "^4.6.4"
    }
}
